# Model provider: tongyi, dashscope, qwen, or openai
MODEL_PROVIDER=tongyi

# Tongyi / DashScope
DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key
OPENAI_MODEL=qwen3-max
OPENAI_EMBEDDING_MODEL=text-embedding-v4

# OpenAI-compatible provider (optional; leave empty when using Tongyi)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Local runtime storage
APP_DATA_DIR=data/runtime
SQLITE_PATH=data/runtime/pet_products.sqlite3
CHROMA_PATH=data/runtime/chroma

# FastAPI model warmup. Keep false when Streamlit and FastAPI share a low-memory machine.
API_PRELOAD_RERANKER=false

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=smart-pet-agent
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=smart-pet-agent

